# Valorant Short Maker — required environment variables

# Groq API key (get one at https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Instagram credentials (instagrapi)
# Username + password OR session ID (session ID is more reliable)
INSTAGRAM_USERNAME=valorant_agents
INSTAGRAM_PASSWORD=your_instagram_password
INSTAGRAM_SESSION_ID=your_instagram_sessionid_cookie

# YouTube Data API v3 — OAuth Desktop app credentials
# Create a project at https://console.cloud.google.com, enable YouTube Data API v3,
# create OAuth 2.0 Client ID (Desktop app), then copy the client ID and secret here
YT_CLIENT_ID=your_google_client_id
YT_CLIENT_SECRET=your_google_client_secret

# Optional
CACHED_DEMO_FILES=1
